  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: Dialogue_ko
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: ko
  m_SharedData: {fileID: 11400000, guid: 77f27e110e04c425b82d6cdd7c9845b4, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 5476121519841280
    m_Localized: "\uC624\uD6C4\uC758 \uBE5B\uC774 \uBE44\uC2A4\uB4EC\uD788 \uC3DF\uC544\uC9C0\uB294
      \uB3C4\uC11C\uAD00. \n\uADF8\uB7F0\uB370 \uC624\uB298\uC740 \uB2EC\uB790\uB2E4.
      \n\uD3C9\uC18C\uC5D4 \uC5C6\uB358 \uC11C\uAC00 \uD558\uB098\uAC00 \uAC00\uC7A5
      \uC548\uCABD\uC5D0 \uC788\uC5C8\uB2E4. \uB9C8\uCE58 \uCC98\uC74C\uBD80\uD130
      \uAC70\uAE30 \uC788\uC5C8\uB358 \uAC83\uCC98\uB7FC."
    m_Metadata:
      m_Items: []
  - m_Id: 5775857422426112
    m_Localized: "      \uC774\uC0C1\uD558\uB2E4. \uC5B4\uC81C\uB3C4 \uC774 \uC790\uB9AC\uB97C
      \uC9C0\uB098\uCCE4\uB294\uB370.\n"
    m_Metadata:
      m_Items: []
  - m_Id: 5855223066124288
    m_Localized: "\uC11C\uAC00 \uB9E8 \uC544\uB798 \uCE78. \n\uBA3C\uC9C0 \uC313\uC778
      \uCC45\uB4E4 \uC0AC\uC774\uC5D0\uC11C \uADF8 \uCC45\uB9CC \uAE68\uB057\uD588\uB2E4.
      \n\uC81C\uBAA9\uB3C4 \uC5C6\uC5C8\uB2E4. \uD45C\uC9C0\uC5D4 "
    m_Metadata:
      m_Items: []
  - m_Id: 5860803176554496
    m_Localized: <sprite name="?"><sprite name="C"><sprite name="D"><sprite name="E"><sprite
      name="!"><sprite name="T"><sprite name="U">
    m_Metadata:
      m_Items: []
  - m_Id: 5866523460624384
    m_Localized: "\uC190\uC744 \uBED7\uC5C8\uB2E4. \uCC28\uAC00\uC6E0\uB2E4. \n\uC774\uC0C1\uD558\uAC8C
      \uCC28\uAC00\uC6E0\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 6195919878873088
    m_Localized: "      \uC77D\uC744 \uC218\uAC00 \uC5C6\uB2E4.\n      \uADF8\uB7F0\uB370
      \uC65C \uC190\uC744 \uB193\uC744 \uC218\uAC00 \uC5C6\uC9C0."
    m_Metadata:
      m_Items: []
  - m_Id: 6197475806273536
    m_Localized: "\uCCAB \uD398\uC774\uC9C0\uAC00 \uC5F4\uB838\uB2E4. \uB2E8 \uD55C
      \uBB38\uC7A5. \n[ \uB2F9\uC2E0\uC758 \uC774\uC57C\uAE30\uAC00 \uC2DC\uC791\uB41C\uB2E4.
      ]"
    m_Metadata:
      m_Items: []
  - m_Id: 6200778329939968
    m_Localized: "\uC138\uACC4\uAC00 \uAE30\uC6B8\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7647536901775360
    m_Localized: "\uB3C4\uC11C\uAD00\uC774 \uC811\uD600\uB4E4\uC5B4\uAC14\uB2E4. "
    m_Metadata:
      m_Items: []
  - m_Id: 7651424308551680
    m_Localized: "\uCC45\uC758 \uD398\uC774\uC9C0\uCC98\uB7FC. \n\uAE00\uC790\uB4E4
      \uC0AC\uC774\uB97C, \uBB38\uC7A5\uB4E4 \uC0AC\uC774\uB97C, \uB2E8\uB77D\uB4E4
      \uC0AC\uC774\uB97C \uCD94\uB77D\uD588\uB2E4. \uADF8\uB9AC\uACE0 \uB545\uC774
      \uC0DD\uACBC\uB2E4. \uBC1C \uBC11\uC5D0, \uAC11\uC790\uAE30.\n"
    m_Metadata:
      m_Items: []
  - m_Id: 7930754171396096
    m_Localized: "      \u2014 \uCD94\uB77D\uD558\uB294 \uB3D9\uC548 \u2014 \uC774
      \uCE74\uB4DC\uAC00 \uB098\uB97C \uBD99\uC7A1\uC740 \uAC83 \uAC19\uB2E4. \n     
      \uC544\uB2C8\uBA74 \uB0B4\uAC00 \uC774 \uCE74\uB4DC\uB97C \uBD99\uC7A1\uC740
      \uAC74\uC9C0\uB3C4.\n      \uC5B4\uCA0C\uB4E0 \u2014 \uC774\uAC83\uC774 \uB098\uB97C
      \uC5EC\uAE30\uB85C \uB370\uB824\uC654\uB2E4.\n"
    m_Metadata:
      m_Items: []
  - m_Id: 7931592923144192
    m_Localized: "\uBAA8\uB4E0 \uAC83\uC774 \uC11C\uC220\uB41C \uAC83\uC774\uC5C8\uB2E4.
      \uB098\uBB34, \uD558\uB298, \uB545. \uC190 \uC548\uC5D0 \uBD88\uAF43 \uCE74\uB4DC\uAC00
      \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7933045041520640
    m_Localized: "      \u2014 \uC5EC\uAE30\uAC00 \uC5B4\uB518\uC9C0 \uC774\uD574\uD588\uB2E4.
      \uCC45 \uC548\uC774\uB2E4. \n      \uC774 \uACF5\uAC04\uC740 \u2014 \uB204\uAD70\uAC00\uAC00
      \uC4F4 \uAC83\uC774\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7933529915645952
    m_Localized: "\uC544\uBB34\uB3C4 \uC5C6\uC5C8\uB2E4. \uC774 \uC138\uACC4\uC5D0\uB294
      \uB2F9\uC2E0\uACFC \uBB38\uC790\uB4E4\uB9CC \uC788\uC5C8\uB2E4.\n"
    m_Metadata:
      m_Items: []
  - m_Id: 7959460654866432
    m_Localized: "\uADF8\uB9AC\uACE0 \u2014 \uB545\uC774 \uAC80\uC5B4\uC9C0\uAE30
      \uC2DC\uC791\uD588\uB2E4. \uAE00\uC790\uB4E4\uC774 \uB179\uC544\uB0B4\uB838\uB2E4.
      \uD758\uB7EC\uB0B4\uB9AC\uACE0, \uBAA8\uC774\uACE0, \uD615\uD0DC\uB97C \uB9CC\uB4E4\uC5B4\uB0C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 7982791412146176
    m_Localized: "      \uC544\uBB34\uB3C4 \uC5C6\uB2E4. \uC774 \uCE74\uB4DC\uB97C
      \u2014 \uADF8\uB0E5 \uBBFF\uC5B4\uC57C \uD55C\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 8008572364382208
    m_Localized: "\uC789\uD06C \uAD34\uBB3C\uC774 [ <slot_1> ]\uC744 \uBC00\uC5B4\uB0B4\uBA70
      \uB2E4\uAC00\uC628\uB2E4."
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
