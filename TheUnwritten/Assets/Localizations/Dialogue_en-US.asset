%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: Dialogue_en-US
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: en-US
  m_SharedData: {fileID: 11400000, guid: 77f27e110e04c425b82d6cdd7c9845b4, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 5476121519841280
    m_Localized: "The library, where the afternoon sun poured in at a slant. Yet,
      today felt different.\nAt the very back stood a bookshelf that had never been
      there before\u2014as if it had belonged there since the very beginning."
    m_Metadata:
      m_Items: []
  - m_Id: 5775857422426112
    m_Localized: '      Strange. I passed this very spot just yesterday.'
    m_Metadata:
      m_Items: []
  - m_Id: 5855223066124288
    m_Localized: "The bottommost shelf. \nAmidst the rows of dust-covered books,
      only that one book was pristine. It had no title. \nOn its cover..."
    m_Metadata:
      m_Items: []
  - m_Id: 5860803176554496
    m_Localized: <sprite name="?"><sprite name="C"><sprite name="D"><sprite name="E"><sprite
      name="!"><sprite name="T"><sprite name="U">
    m_Metadata:
      m_Items: []
  - m_Id: 5866523460624384
    m_Localized: "I reached out. It was cold. \nStrangely cold."
    m_Metadata:
      m_Items: []
  - m_Id: 6195919878873088
    m_Localized: "      I cannot read it. \n      And yet, why can't I let go?"
    m_Metadata:
      m_Items: []
  - m_Id: 6197475806273536
    m_Localized: 'The first page fell open. A single sentence.

      [ your story
      begins. ]'
    m_Metadata:
      m_Items: []
  - m_Id: 6200778329939968
    m_Localized: The world tilted.
    m_Metadata:
      m_Items: []
  - m_Id: 7647536901775360
    m_Localized: The library folded in on itself.
    m_Metadata:
      m_Items: []
  - m_Id: 7651424308551680
    m_Localized: "Like the pages of a book, \nI fell\u2014plunging between letters,
      between sentences, and between paragraphs. And then, the ground appeared. Suddenly,
      beneath my feet."
    m_Metadata:
      m_Items: []
  - m_Id: 7930754171396096
    m_Localized: "      During the fall \u2014 I think this card caught me. \n     
      Or I caught it.\n      Either way \u2014 this is what brought me here."
    m_Metadata:
      m_Items: []
  - m_Id: 7931592923144192
    m_Localized: "Everything was written. The trees, the sky, the ground. In my hand
      \u2014 a Flame card."
    m_Metadata:
      m_Items: []
  - m_Id: 7933045041520640
    m_Localized: "      \u2014 I understood where I was. \n      Inside the book.
      \n      This place \u2014 someone had written it.\n"
    m_Metadata:
      m_Items: []
  - m_Id: 7933529915645952
    m_Localized: "There was no one. In this world, only you and the letters remained.
      Then \u2014 the ground began to blacken."
    m_Metadata:
      m_Items: []
  - m_Id: 7959460654866432
    m_Localized: The letters melted. They poured down, gathered, and shaped themselves.
    m_Metadata:
      m_Items: []
  - m_Id: 7982791412146176
    m_Localized: "      \u2014 In this world\u2026 to write is to obtain?\n     
      A name I haven't yet read rests in my hand."
    m_Metadata:
      m_Items: []
  - m_Id: 8008572364382208
    m_Localized: The Ink Creature pushes<slot_1>.
    m_Metadata:
      m_Items: []
  - m_Id: 8658564787724288
    m_Localized: "\uBD88\uAF43\uC774 \uAC80\uC740 \uBAB8\uCCB4\uB97C \uD565\uC558\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 8659217266237440
    m_Localized: "\uC789\uD06C \uAD34\uBB3C\uC758 \uC724\uACFD\uC774 \uC7A0\uC2DC
      \uD750\uD2B8\uB7EC\uC84C\uB2E4.\n\uD558\uC9C0\uB9CC \uBA48\uCD94\uC9C0\uB294
      \uC54A\uC558\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 8659316344086528
    m_Localized: "\uC789\uD06C \uAD34\uBB3C\uC774 \uB2F9\uC2E0\uC744 \uD5A5\uD574
      \uBD09\uC778\uC5D0 \uBB36\uC778 \uCC44 \uBC00\uB824\uC628\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 8659961260269568
    m_Localized: "\uAC80\uC740 \uAE00\uC790\uB4E4\uC774 \uACF5\uC911\uC5D0\uC11C
      \uBA48\uCE6B\uD588\uB2E4.\n\n\uBB38\uC7A5\uC758 \uB05D\uC774 \uC7A0\uAE50 \uB2EB\uD614\uB2E4.\n\uADF8
      \uD2C8\uC5D0, \uB2F9\uC2E0\uC740 \uC228\uC744 \uACE0\uB97C \uC218 \uC788\uC5C8\uB2E4."
    m_Metadata:
      m_Items: []
  - m_Id: 9000000000000001
    m_Localized: "A thread of the black current \u2014 leapt to your fingertip. It
      was cold. And, familiar.\nOn your palm, it became a single card."
    m_Metadata:
      m_Items: []
  - m_Id: 9000000000000002
    m_Localized: ' darkness '
    m_Metadata:
      m_Items: []
  - m_Id: 9000000000000003
    m_Localized: ' flame '
    m_Metadata:
      m_Items: []
  - m_Id: 9000000000000004
    m_Localized: "      <color=#1D4A52>\u2014 Stopped by what you yourself gave.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 9000000000000005
    m_Localized: "      <color=#1D4A52>\u2014 That black card just now\u2026 I'll
      read it later.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 9000000000000006
    m_Localized: "\uC789\uD06C\uAC00 \uB2E4\uC2DC \uBAA8\uC600\uB2E4. \uD55C \uBC88
      \uD769\uC5B4\uC84C\uB2E4\uAC00 \u2014 \uB354 \uD070 \uD615\uC0C1\uC73C\uB85C.
      \n\uAE00\uC790\uB4E4\uC774 \uBE60\uB974\uAC8C \uBE60\uC838\uB098\uAC00\uACE0
      \uC788\uB2E4. \uC774 \uC138\uACC4\uC758 \uB2E8\uC5B4\uB4E4\uC774 \u2014 \uC800
      \uC548\uC73C\uB85C."
    m_Metadata:
      m_Items: []
  - m_Id: 10519838404370432
    m_Localized: "<sprite name=\"W\"><sprite name=\"R\"><sprite name=\"I\"><sprite
      name=\"T\"><sprite name=\"T\"><sprite name=\"E\"><sprite name=\"N\"><color=#6A1B9A><color=#54157B>\uC678\uBD80\uC790.
      \uC11C\uC220\uC744 \uBB34\uB2E8 \uBCC0\uACBD\uD558\uC600\uB2E4. \uC81C\uAC70
      \uB300\uC0C1\uC73C\uB85C \uC9C0\uC815\uD55C\uB2E4.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 10525632122314752
    m_Localized: "<color=#6A1B9A>\uC678\uBD80\uC790. \uC11C\uC220\uC744 \uBB34\uB2E8
      \uBCC0\uACBD\uD558\uC600\uB2E4. \uC81C\uAC70 \uB300\uC0C1\uC73C\uB85C \uC9C0\uC815\uD55C\uB2E4.</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 10547295048163328
    m_Localized: "      <color=#1D4A52>\uCE74\uB4DC\uB97C \uC4F4\uB2E4\uB294 \uAC74
      \u2014 \uC774 \uC138\uACC4\uC758 \uB9D0\uC744 \uBE4C\uB9AC\uB294 \uAC83\uC774\uB2E4.</color>\n     
      <color=#1D4A52>\uBE4C\uB9AC\uC9C0 \uC54A\uC73C\uBA74, \uC800 \uAD34\uBB3C\uC774
      \uB9C8\uC800 \uAC00\uC838\uAC04\uB2E4.</color>"
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
